{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "1.1.0",
  "default_locale": "en",
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extensionName__"
  },
  "background": {
    "scripts": ["i18n.js", "background.js"]
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://prayertimes.api.abdus.dev/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vakit-takibi@extension.id",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
