{
  "manifest_version": 2,
  "name": "Vakit Takibi",
  "version": "1.0",
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "https://vakit.vercel.app/*"
  ]
}
